# Copie para .env e ajuste se quiser (docker-compose usa esses valores)
# cp .env.example .env

# Usuário/grupo no container (evita permissão de log). Linux: 50000 costuma funcionar.
AIRFLOW_UID=50000

# Postgres (usado pelo Airflow para metadados)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Usuário admin da interface web do Airflow (criado pelo airflow-init)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# AWS (opcional; para DAGs que acessam S3 use perfil default ou defina aqui)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
